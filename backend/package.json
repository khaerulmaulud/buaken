{
  "name": "food-delivery-backend",
  "version": "1.0.0",
  "description": "Food delivery system backend with Express, Drizzle ORM, and PostgreSQL",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "test": "tsx tests/run-tests.ts",
    "lint:format": "pnpm exec biome format --write",
    "lint:fix": "pnpm exec biome check --write",
    "lint": "pnpm exec biome lint"
  },
  "keywords": [
    "food-delivery",
    "express",
    "drizzle",
    "typescript",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "@t3-oss/env-core": "^0.13.10",
    "bcryptjs": "^2.4.3",
    "cli-table3": "^0.6.5",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.38.4",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "file-type": "16.5.4",
    "helmet": "^8.1.0",
    "inquirer": "^13.2.2",
    "jsonwebtoken": "^9.0.3",
    "mathjs": "^15.1.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.1",
    "postgres": "^3.4.8",
    "sanitize-html": "^2.17.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.32",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-erd": "0.0.1-alpha.11",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.39.2",
    "glob": "^13.0.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
