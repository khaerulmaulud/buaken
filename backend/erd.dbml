enum chat_message_type {
  text
  image
}

enum chat_room_type {
  customer_merchant
  customer_courier
  merchant_courier
}

enum chat_sender_role {
  customer
  merchant
  courier
  system
}

enum complaint_category {
  order_not_received
  wrong_order
  merchant_fraud
  courier_issue
  payment_problem
  quality_issue
  other
}

enum complaint_status {
  pending
  in_review
  resolved
  closed
}

enum order_status {
  pending
  confirmed
  preparing
  ready_for_pickup
  picked_up
  on_delivery
  delivered
  cancelled
}

enum payment_method {
  cash
  digital_wallet
  bank_transfer
}

enum payment_status {
  pending
  paid
  refunded
}

enum user_role {
  customer
  merchant
  courier
  admin
}

enum vehicle_type {
  motorcycle
  bicycle
  car
}

table categories {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  name varchar(100) [not null]
  slug varchar(100) [not null, unique]
  icon_url varchar(500)
  created_at timestamp [not null, default: `now()`]
}

table chat_messages {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  room_id uuid [not null]
  sender_id uuid [not null]
  sender_role chat_sender_role [not null]
  content text [not null]
  message_type chat_message_type [not null, default: 'text']
  image_url varchar(500)
  is_read boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]

  indexes {
    (room_id, created_at) [name: 'chat_messages_room_id_idx']
    sender_id [name: 'chat_messages_sender_id_idx']
    is_read [name: 'chat_messages_is_read_idx']
  }
}

table chat_rooms {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  order_id uuid [not null]
  type chat_room_type [not null]
  is_archived boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    order_id [name: 'chat_rooms_order_id_idx']
    type [name: 'chat_rooms_type_idx']
    is_archived [name: 'chat_rooms_status_idx']
    (order_id, type) [name: 'chat_rooms_order_type_unique_idx']
  }
}

table complaint_messages {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  complaint_id uuid [not null]
  sender_id uuid [not null]
  content text [not null]
  image_url varchar(500)
  created_at timestamp [not null, default: `now()`]
}

table complaints {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  reporter_id uuid [not null]
  category complaint_category [not null]
  subject varchar(255) [not null]
  description text [not null]
  order_id uuid
  status complaint_status [not null, default: 'pending']
  assigned_admin_id uuid
  admin_notes text
  resolution text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  resolved_at timestamp
}

table courier_profiles {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null, unique]
  vehicle_type vehicle_type [not null]
  vehicle_number varchar(50) [not null]
  is_online boolean [not null, default: false]
  current_latitude varchar(50)
  current_longitude varchar(50)
  total_deliveries integer [not null, default: 0]
  rating "numeric(3, 2)" [not null, default: '0']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    user_id [name: 'courier_profiles_user_id_idx']
  }
}

table menu_items {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  merchant_id uuid [not null]
  category_id uuid [not null]
  name varchar(255) [not null]
  description text [not null]
  price "numeric(10, 2)" [not null]
  image_url varchar(500)
  is_available boolean [not null, default: true]
  stock integer
  preparation_time integer [not null]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    merchant_id [name: 'menu_items_merchant_id_idx']
    category_id [name: 'menu_items_category_id_idx']
    name [name: 'menu_items_name_idx']
  }
}

table merchants {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null, unique]
  store_name varchar(255) [not null]
  description text [not null]
  logo_url varchar(500)
  banner_url varchar(500)
  address_line text [not null]
  latitude varchar(50) [not null]
  longitude varchar(50) [not null]
  city varchar(100) [not null]
  phone varchar(20) [not null]
  is_open boolean [not null, default: true]
  rating "numeric(3, 2)" [not null, default: '0']
  total_reviews integer [not null, default: 0]
  opening_time time [not null]
  closing_time time [not null]
  delivery_fee "numeric(10, 2)" [not null]
  min_order "numeric(10, 2)" [not null]
  estimated_delivery_time integer [not null]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    user_id [name: 'merchants_user_id_idx']
    city [name: 'merchants_city_idx']
    is_open [name: 'merchants_is_open_idx']
  }
}

table order_items {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  order_id uuid [not null]
  menu_item_id uuid [not null]
  quantity integer [not null]
  price "numeric(10, 2)" [not null]
  notes text
  created_at timestamp [not null, default: `now()`]

  indexes {
    order_id [name: 'order_items_order_id_idx']
  }
}

table orders {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  order_number varchar(50) [not null, unique]
  customer_id uuid [not null]
  merchant_id uuid [not null]
  courier_id uuid
  delivery_address_id uuid [not null]
  delivery_notes text
  subtotal "numeric(10, 2)" [not null]
  delivery_fee "numeric(10, 2)" [not null]
  service_fee "numeric(10, 2)" [not null, default: '0']
  total_amount "numeric(10, 2)" [not null]
  status order_status [not null, default: 'pending']
  payment_method payment_method [not null]
  payment_status payment_status [not null, default: 'pending']
  created_at timestamp [not null, default: `now()`]
  confirmed_at timestamp
  picked_up_at timestamp
  delivered_at timestamp
  cancelled_at timestamp
  cancellation_reason text

  indexes {
    (customer_id, created_at) [name: 'orders_customer_id_idx']
    (merchant_id, created_at) [name: 'orders_merchant_id_idx']
    (courier_id, created_at) [name: 'orders_courier_id_idx']
    status [name: 'orders_status_idx']
    (merchant_id, status) [name: 'orders_merchant_status_idx']
    (courier_id, status) [name: 'orders_courier_status_idx']
  }
}

table reviews {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  order_id uuid
  customer_id uuid [not null]
  merchant_id uuid
  courier_id uuid
  menu_item_id uuid
  rating integer [not null]
  comment text
  image_url text
  image_urls text[]
  merchant_reply text
  replied_at timestamp
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

table user_addresses {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  label varchar(100) [not null]
  address_line text [not null]
  latitude varchar(50) [not null]
  longitude varchar(50) [not null]
  city varchar(100) [not null]
  postal_code varchar(20) [not null]
  notes text
  is_default boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]

  indexes {
    user_id [name: 'user_addresses_user_id_idx']
  }
}

table users {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  email varchar(255) [not null, unique]
  password varchar(255) [not null]
  name varchar(255) [not null]
  phone varchar(20) [not null]
  role user_role [not null]
  avatar_url varchar(500)
  is_verified boolean [not null, default: false]
  is_active boolean [not null, default: true]
  reset_password_token varchar(255)
  reset_password_expires timestamp
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

ref chat_messages_room_id_chat_rooms_id_fk: chat_messages.room_id > chat_rooms.id [delete: cascade, update: no action]

ref chat_messages_sender_id_users_id_fk: chat_messages.sender_id > users.id [delete: cascade, update: no action]

ref chat_rooms_order_id_orders_id_fk: chat_rooms.order_id > orders.id [delete: cascade, update: no action]

ref complaint_messages_complaint_id_complaints_id_fk: complaint_messages.complaint_id > complaints.id [delete: cascade, update: no action]

ref complaint_messages_sender_id_users_id_fk: complaint_messages.sender_id > users.id [delete: cascade, update: no action]

ref complaints_reporter_id_users_id_fk: complaints.reporter_id > users.id [delete: cascade, update: no action]

ref complaints_order_id_orders_id_fk: complaints.order_id > orders.id [delete: set null, update: no action]

ref complaints_assigned_admin_id_users_id_fk: complaints.assigned_admin_id > users.id [delete: set null, update: no action]

ref courier_profiles_user_id_users_id_fk: courier_profiles.user_id > users.id [delete: cascade, update: no action]

ref menu_items_merchant_id_merchants_id_fk: menu_items.merchant_id > merchants.id [delete: cascade, update: no action]

ref menu_items_category_id_categories_id_fk: menu_items.category_id > categories.id [delete: restrict, update: no action]

ref merchants_user_id_users_id_fk: merchants.user_id > users.id [delete: cascade, update: no action]

ref order_items_order_id_orders_id_fk: order_items.order_id > orders.id [delete: cascade, update: no action]

ref order_items_menu_item_id_menu_items_id_fk: order_items.menu_item_id > menu_items.id [delete: restrict, update: no action]

ref orders_customer_id_users_id_fk: orders.customer_id > users.id [delete: restrict, update: no action]

ref orders_merchant_id_merchants_id_fk: orders.merchant_id > merchants.id [delete: restrict, update: no action]

ref orders_courier_id_users_id_fk: orders.courier_id > users.id [delete: set null, update: no action]

ref orders_delivery_address_id_user_addresses_id_fk: orders.delivery_address_id > user_addresses.id [delete: restrict, update: no action]

ref reviews_order_id_orders_id_fk: reviews.order_id > orders.id [delete: cascade, update: no action]

ref reviews_customer_id_users_id_fk: reviews.customer_id > users.id [delete: cascade, update: no action]

ref reviews_merchant_id_merchants_id_fk: reviews.merchant_id > merchants.id [delete: cascade, update: no action]

ref reviews_courier_id_courier_profiles_id_fk: reviews.courier_id > courier_profiles.id [delete: cascade, update: no action]

ref reviews_menu_item_id_menu_items_id_fk: reviews.menu_item_id > menu_items.id [delete: cascade, update: no action]

ref user_addresses_user_id_users_id_fk: user_addresses.user_id > users.id [delete: cascade, update: no action]